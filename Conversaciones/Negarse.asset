  m_Script: {fileID: 11500000, guid: 8adeb66ea48d6884c9ae1c35b5ca9e1a, type: 3}
  m_Name: Negarse
  m_EditorClassIdentifier: Assembly-CSharp::DialogueScript
  defaultPanelType: 0
  nextConversation: {fileID: 0}
  changeSceneOnEnd: 1
  sceneToLoadOnEnd: Pueblo de Noche
  conversationLines:
  - speaker: Francois
    text: "No, \xBFacaso quieres terminar colgada en la plaza? \xBFo ser encarcelada?"
    showImage: 1
    characterImage: {fileID: 3850027480385225625, guid: 61e58d5789b358445b85b781cf208851, type: 3}
    imagePosition: 0
    characterImageSize: {x: 0, y: 0}
    panelType: 0
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
  - speaker: Elodie
    text: "Fran\xE7ois, ambos sabremos que ir\xE9 sola aunque no me acompa\xF1es
      \u2500\u2500\u2500\u2500\u2500una sonrisa juguetona sali\xF3 de sus labios\u2026
      desafiandome."
    showImage: 1
    characterImage: {fileID: 3850027480385225625, guid: 61e58d5789b358445b85b781cf208851, type: 3}
    imagePosition: 0
    characterImageSize: {x: 0, y: 0}
    panelType: 0
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
  - speaker: 
    text: "Maldita sea, era d\xE9bil ante estos chantajes.\r\n"
    showImage: 1
    characterImage: {fileID: 3850027480385225625, guid: 61e58d5789b358445b85b781cf208851, type: 3}
    imagePosition: 0
    characterImageSize: {x: 0, y: 0}
    panelType: 1
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
  - speaker: Francois
    text: "\xA1Bien, bien! Te acompa\xF1ar\xE9 \u2500\u2500\u2500\u2500\u2500mi voz
      sali\xF3 resignada.\r\n"
    showImage: 1
    characterImage: {fileID: 3850027480385225625, guid: 61e58d5789b358445b85b781cf208851, type: 3}
    imagePosition: 0
    characterImageSize: {x: 0, y: 0}
    panelType: 1
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
  - speaker: Elodie
    text: "Elodie me abraz\xF3 con una sonrisa enorme, no pod\xEDa realmente decirle
      que no."
    showImage: 1
    characterImage: {fileID: 168661227485434523, guid: 17bfadfbd598e5e4b8abcaf37a53538d, type: 3}
    imagePosition: 0
    characterImageSize: {x: 0, y: 0}
    panelType: 1
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
