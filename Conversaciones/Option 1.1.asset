  conversationLines:
  - speaker: 'Francois '
    text: "Y t\xFA tienes unos labios muy parlanchines, Elodie."
    showImage: 1
    characterImage: {fileID: 3850027480385225625, guid: 61e58d5789b358445b85b781cf208851, type: 3}
