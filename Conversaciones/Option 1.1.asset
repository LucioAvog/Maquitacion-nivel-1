    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
  - speaker: 
    text: "Vi como jadeaba ofendida para luego rodar los ojos, y quedar con el ce\xF1o
      fruncido sin estar realmente enojada.\r\n"
    showImage: 1
    characterImage: {fileID: 3850027480385225625, guid: 61e58d5789b358445b85b781cf208851, type: 3}
    imagePosition: 0
    characterImageSize: {x: 300, y: 400}
    panelType: 1
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
  - speaker: Elodie
    text: "Lo que digas. Ven\xEDa a regalarte una manzana."
