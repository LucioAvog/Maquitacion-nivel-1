MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8adeb66ea48d6884c9ae1c35b5ca9e1a, type: 3}
  m_Name: Pueblo
  m_EditorClassIdentifier: Assembly-CSharp::DialogueScript
  defaultPanelType: 0
  nextConversation: {fileID: 0}
  changeSceneOnEnd: 1
  sceneToLoadOnEnd: Regreso al Pueblo
  conversationLines:
  - speaker: 
    text: "El comerciante apenas levant\xF3 la vista al vernos. Parec\xEDa estar
      guardando las cosas, el lugar casi vac\xEDo.\r\n"
    showImage: 0
    characterImage: {fileID: 1746383676720419681, guid: 8bfdc9237ca903b44ad9b064fb315cc0, type: 3}
    imagePosition: 0
    characterImageSize: {x: 0, y: 0}
    panelType: 1
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
  - speaker: Elodie
    text: "\xA1Monsieur Julian! \xBFQu\xE9 sucede? \xBFA d\xF3nde va?"
    showImage: 1
    characterImage: {fileID: 3850027480385225625, guid: 61e58d5789b358445b85b781cf208851, type: 3}
    imagePosition: 0
    characterImageSize: {x: 0, y: 0}
    panelType: 0
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
  - speaker: Julian (Comerciante)
    text: "Oh, Elodie. Estoy cerrando el mercado, no vale la pena vender alimentos.
      Est\xE1n todos muy empobrecidos\u2026 \xBFDe qu\xE9 sirve venir aqu\xED todos
      los d\xEDas si nadie compra?\r\n"
    showImage: 1
    characterImage: {fileID: 1746383676720419681, guid: 8bfdc9237ca903b44ad9b064fb315cc0, type: 3}
    imagePosition: 0
    characterImageSize: {x: 0, y: 0}
    panelType: 0
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
  - speaker: Francois Mercier
    text: "\xBFNo est\xE1 teniendo clientes? \u2500\u2500\u2500\u2500\u2500pregunt\xE9
      confundido.\r\n"
    showImage: 1
    characterImage: {fileID: 1746383676720419681, guid: 8bfdc9237ca903b44ad9b064fb315cc0, type: 3}
    imagePosition: 0
    characterImageSize: {x: 0, y: 0}
    panelType: 0
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
  - speaker: Julian (Comerciante)
    text: "\xBFCreen que la gente est\xE1 en condiciones de pagar por mis productos?
      \u2500\u2500\u2500\u2500\u2500respondi\xF3 con cierta iron\xEDa."
    showImage: 1
    characterImage: {fileID: 6626444882373328890, guid: 778bf785afa031b40803d7610f4a61ec, type: 3}
    imagePosition: 0
    characterImageSize: {x: 0, y: 0}
    panelType: 0
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
  - speaker: Elodie
    text: "Entonces\u2026 \xBFEst\xE1s cerrando? \u2500\u2500\u2500\u2500\u2500murmur\xF3
      Eloide algo preocupada."
    showImage: 1
    characterImage: {fileID: 3850027480385225625, guid: 61e58d5789b358445b85b781cf208851, type: 3}
    imagePosition: 0
    characterImageSize: {x: 0, y: 0}
    panelType: 0
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
  - speaker: Julian (Comerciante)
    text: "S\xED\u2026 \xBFAcaso tengo otra opci\xF3n? \u2500\u2500\u2500\u2500\u2500fue
      lo \xFAltimo que mencion\xF3 antes de marcharse.\r\n"
    showImage: 1
    characterImage: {fileID: -8261685616980729567, guid: c4831805765c5db46b1c447cf15bb6e1, type: 3}
    imagePosition: 0
    characterImageSize: {x: 0, y: 0}
    panelType: 0
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
  - speaker: 
    text: "Con Elodie suspiramos. Debemos volver al campo, tal vez ma\xF1ana tendr\xEDamos
      m\xE1s \xE9xito.\r\n"
    showImage: 0
    characterImage: {fileID: 0}
    imagePosition: 0
    characterImageSize: {x: 0, y: 0}
    panelType: 1
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
