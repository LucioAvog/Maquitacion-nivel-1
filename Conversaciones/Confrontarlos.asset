  changeSceneOnEnd: 0
  sceneToLoadOnEnd: 
  conversationLines:
  - speaker: Francois
    text: "\xBF\xA1Qu\xE9 les sucede!? \xA1D\xE9jenlo en paz, es inocente! \u2500\u2500\u2500\u2500\u2500les
      grit\xE9, provocando que me mirara. \r\n"
    showImage: 0
    characterImage: {fileID: 0}
    imagePosition: 0
    characterImageSize: {x: 0, y: 0}
    panelType: 0
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
  - speaker: 
    text: "Mi arrepentimiento fue instant\xE1neo, al observar que la espada del guardia
      segu\xEDa en sus manos. Sin embargo, no fui degollado. \xC9l me observ\xF3
      un momento, murmur\xF3 algo a su compa\xF1ero y se alej\xF3."
    showImage: 0
    characterImage: {fileID: 0}
    imagePosition: 0
    characterImageSize: {x: 0, y: 0}
    panelType: 1
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
  - speaker: 
    text: "Tal vez me recuerden en un futuro\u2026 tragu\xE9 saliva con fuerza, la
      idea me aferraba. No era un hombre muy valiente para esto\u2026 \r\n"
    showImage: 0
    characterImage: {fileID: 0}
    imagePosition: 0
    characterImageSize: {x: 0, y: 0}
    panelType: 1
    newBackground: {fileID: 0}
    triggerShake: 0
    shakeDuration: 0
    shakeIntensity: 0
    choicePanelType: 0
    choices: []
